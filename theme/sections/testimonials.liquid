{% comment %}
  sections/testimonials.liquid
  Social proof section with a proof summary rail and testimonial cards.
{% endcomment %}

{%- liquid
  assign bg_style = section.settings.background_style | default: 'cream'
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign section_id = 'TestimonialsHeading-' | append: section.id
-%}

<section
  class="testimonials section-padding testimonials--bg-{{ bg_style }}"
  aria-labelledby="{{ section_id }}"
>
  <div class="container">
    {%- if eyebrow != blank or heading != blank or subheading != blank -%}
      <header class="testimonials__header">
        {%- if eyebrow != blank -%}
          <p class="testimonials__eyebrow">{{ eyebrow | escape }}</p>
        {%- endif -%}
        {%- if heading != blank -%}
          <h2 class="testimonials__heading" id="{{ section_id }}">{{ heading | escape }}</h2>
        {%- endif -%}
        {%- if subheading != blank -%}
          <p class="testimonials__subheading">{{ subheading | escape }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="testimonials__summary" aria-label="Store proof points">
      <div class="testimonials__summary-item">
        <strong class="testimonials__summary-value">{{ section.settings.proof_1_value | default: '48' | escape }}</strong>
        <span class="testimonials__summary-label">{{ section.settings.proof_1_label | default: 'Years serving North Myrtle Beach' | escape }}</span>
      </div>
      <div class="testimonials__summary-item">
        <strong class="testimonials__summary-value">{{ section.settings.proof_2_value | default: '50+' | escape }}</strong>
        <span class="testimonials__summary-label">{{ section.settings.proof_2_label | default: 'Brands across comfort, performance, and dance' | escape }}</span>
      </div>
      <div class="testimonials__summary-item">
        <strong class="testimonials__summary-value">{{ section.settings.proof_3_value | default: '1:1' | escape }}</strong>
        <span class="testimonials__summary-label">{{ section.settings.proof_3_label | default: 'Personal fit help in store' | escape }}</span>
      </div>
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="testimonials__grid" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'testimonial' -%}
            {%- liquid
              assign rating = block.settings.rating | default: 5 | plus: 0
            -%}
            <article class="testimonial-card{% if bg_style == 'card' %} testimonial-card--card{% endif %}" role="listitem" {{ block.shopify_attributes }}>
              <span class="testimonial-card__quote-mark" aria-hidden="true">&ldquo;</span>

              <div class="testimonial-card__stars" aria-label="{{ rating }} out of 5 stars" role="img">
                {%- for i in (1..5) -%}
                  {%- if i <= rating -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="0.5" class="testimonial-card__star testimonial-card__star--filled" aria-hidden="true" focusable="false">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                    </svg>
                  {%- else -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="testimonial-card__star" aria-hidden="true" focusable="false">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                    </svg>
                  {%- endif -%}
                {%- endfor -%}
              </div>

              {%- if block.settings.quote != blank -%}
                <blockquote class="testimonial-card__text">
                  <p>{{ block.settings.quote | escape }}</p>
                </blockquote>
              {%- endif -%}

              {%- if block.settings.author != blank -%}
                <footer class="testimonial-card__author">{{ block.settings.author | escape }}</footer>
              {%- endif -%}
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .testimonials--bg-cream {
    background-color: var(--color-bg, #F6F4EF);
  }

  .testimonials--bg-card {
    background-color: var(--color-card, #FFFFFF);
  }

  .testimonials__header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-bottom: 28px;
  }

  .testimonials__eyebrow {
    margin: 0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-secondary, #5b6368);
  }

  .testimonials__heading {
    margin: 0;
    font-size: clamp(28px, 4vw, 44px);
    line-height: 1.08;
    color: var(--color-heading, #18242E);
  }

  .testimonials__subheading {
    max-width: 560px;
    margin: 0;
    font-size: clamp(15px, 1.6vw, 17px);
    line-height: 1.65;
    color: var(--color-text-secondary, #5b6368);
  }

  .testimonials__summary {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin: 0 auto 42px;
    border-radius: 24px;
    overflow: hidden;
    background-color: var(--color-card, #FFFFFF);
    border: 1px solid rgba(24, 36, 46, 0.10);
    box-shadow: 0 14px 30px rgba(24, 36, 46, 0.05);
  }

  .testimonials__summary-item {
    padding: 28px 24px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .testimonials__summary-item + .testimonials__summary-item {
    border-left: 1px solid rgba(24, 36, 46, 0.08);
  }

  .testimonials__summary-value {
    font-size: clamp(34px, 4vw, 48px);
    line-height: 1;
    color: var(--color-heading, #18242E);
  }

  .testimonials__summary-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    line-height: 1.5;
    color: var(--color-text-secondary, #5b6368);
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 28px;
  }

  .testimonial-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 32px 28px 28px;
    background-color: var(--color-card, #FFFFFF);
    border: 1px solid rgba(24, 36, 46, 0.10);
    border-top: 4px solid rgba(24, 36, 46, 0.16);
    border-radius: 20px;
    box-shadow: 0 10px 24px rgba(24, 36, 46, 0.04);
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .testimonials--bg-card .testimonial-card {
    background-color: var(--color-bg, #F6F4EF);
  }

  .testimonial-card--card {
    background-color: var(--color-card, #FFFFFF);
  }

  .testimonial-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 36px rgba(24, 36, 46, 0.08);
  }

  .testimonial-card__quote-mark {
    display: block;
    height: 28px;
    margin-bottom: 4px;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 64px;
    line-height: 0.6;
    color: rgba(24, 36, 46, 0.16);
    user-select: none;
  }

  .testimonial-card__stars {
    display: flex;
    gap: 3px;
    align-items: center;
  }

  .testimonial-card__star {
    color: rgba(24, 36, 46, 0.22);
  }

  .testimonial-card__star--filled {
    color: #C48B3B;
  }

  .testimonial-card__text {
    margin: 0;
    flex: 1;
  }

  .testimonial-card__text p {
    margin: 0;
    font-size: 15px;
    line-height: 1.75;
    color: var(--color-text, #2E3438);
    font-style: italic;
  }

  .testimonial-card__author {
    padding-top: 8px;
    border-top: 1px solid rgba(24, 36, 46, 0.08);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-heading, #18242E);
  }

  @media (max-width: 1023px) {
    .testimonials__summary {
      grid-template-columns: 1fr;
    }

    .testimonials__summary-item + .testimonials__summary-item {
      border-left: 0;
      border-top: 1px solid rgba(24, 36, 46, 0.08);
    }

    .testimonials__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 599px) {
    .testimonials__header {
      margin-bottom: 24px;
    }

    .testimonials__summary {
      margin-bottom: 28px;
    }

    .testimonials__grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonial-card,
    .testimonial-card:hover {
      transform: none;
      transition: box-shadow 0.25s ease;
    }
  }
</style>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "testimonials-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Trusted locally"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real comfort. Real people. Real North Myrtle Beach."
    },
    {
      "type": "text",
      "id": "proof_1_value",
      "label": "Proof 1 value",
      "default": "48"
    },
    {
      "type": "text",
      "id": "proof_1_label",
      "label": "Proof 1 label",
      "default": "Years serving North Myrtle Beach"
    },
    {
      "type": "text",
      "id": "proof_2_value",
      "label": "Proof 2 value",
      "default": "50+"
    },
    {
      "type": "text",
      "id": "proof_2_label",
      "label": "Proof 2 label",
      "default": "Brands across comfort, performance, and dance"
    },
    {
      "type": "text",
      "id": "proof_3_value",
      "label": "Proof 3 value",
      "default": "1:1"
    },
    {
      "type": "text",
      "id": "proof_3_label",
      "label": "Proof 3 label",
      "default": "Personal fit help in store"
    },
    {
      "type": "select",
      "id": "background_style",
      "label": "Background",
      "options": [
        { "value": "cream", "label": "Cream" },
        { "value": "card", "label": "White / Card" }
      ],
      "default": "cream"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Best shoe-fitting experience I've ever had. They actually measure your foot."
