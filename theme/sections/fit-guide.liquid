    { "type": "text", "id": "title_5", "label": "Title 5", "default": "Dance-ready picks" },
    { "type": "textarea", "id": "copy_5", "label": "Copy 5", "default": "Styles made for Shag nights, events, and shoes that look right and move well." },
    { "type": "text", "id": "link_label_5", "label": "Link label 5", "default": "Shop dance" },
    { "type": "url", "id": "link_5", "label": "Link 5" }
  ],
  "presets": [
    { "name": "Fit guide" }
  ]
}
{% endschema %}
