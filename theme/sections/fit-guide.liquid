    { "type": "url", "id": "link_3", "label": "Link 3" },
    { "type": "text", "id": "badge_4", "label": "Badge 4", "default": "Style" },
    { "type": "text", "id": "title_4", "label": "Title 4", "default": "Style-Forward Picks" },
    { "type": "textarea", "id": "copy_4", "label": "Copy 4", "default": "Fresh silhouettes, modern brands, and newer looks that still feel great on your feet." },
    { "type": "text", "id": "link_label_4", "label": "Link label 4", "default": "Shop style" },
    { "type": "url", "id": "link_4", "label": "Link 4" },
