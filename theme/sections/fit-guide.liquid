    { "type": "text", "id": "link_label_1", "label": "Link label 1", "default": "Shop comfort" },
    { "type": "url", "id": "link_1", "label": "Link 1" },
    { "type": "text", "id": "badge_2", "label": "Badge 2", "default": "Performance" },
    { "type": "text", "id": "title_2", "label": "Title 2", "default": "On and active styles" },
