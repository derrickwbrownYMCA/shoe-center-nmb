{% comment %}
  sections/category-tiles.liquid
  Homepage category grid with local asset fallbacks.
{% endcomment %}

{%- liquid
  if section.settings.heading != blank
    assign tile_heading_tag = 'h3'
  else
    assign tile_heading_tag = 'h2'
  endif

  case section.settings.aspect_ratio
    when 'square'
      assign tile_aspect = '1 / 1'
    when 'portrait'
      assign tile_aspect = '4 / 5'
    when 'tall'
      assign tile_aspect = '3 / 4'
    else
      assign tile_aspect = '4 / 5'
  endcase

  assign desktop_cols = section.settings.columns | default: 4
-%}

<section
  class="cat-tiles section-padding"
  aria-labelledby="{% if section.settings.heading != blank %}CatTilesHeading-{{ section.id }}{% endif %}"
  {% if section.settings.heading == blank %}aria-label="Shop by category"{% endif %}
>
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <header class="cat-tiles__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="cat-tiles__heading" id="CatTilesHeading-{{ section.id }}">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class="cat-tiles__subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul
        class="cat-tiles__grid"
        role="list"
        style="--desktop-cols: {{ desktop_cols }}; --tile-aspect: {{ tile_aspect }};"
      >
        {%- for block in section.blocks -%}
          {%- liquid
            assign tile_title = block.settings.title | default: 'Category'
            assign fallback_alt = tile_title | append: ' image'
            assign title_downcase = tile_title | downcase

            if title_downcase contains 'women'
              assign fallback_alt = 'Woman in a light dress lifting her leg, wearing stylish shoes'
            elsif title_downcase contains 'men'
              assign fallback_alt = 'Man tying a shoe'
            elsif title_downcase contains 'on' or title_downcase contains 'athletic' or title_downcase contains 'performance'
              assign fallback_alt = 'Woman tying an athletic shoe'
            elsif title_downcase contains 'dance'
              assign fallback_alt = 'Dance lifestyle image'
            elsif title_downcase contains 'sale'
              assign fallback_alt = 'Sale category image'
            endif
          -%}

          <li class="cat-tiles__item" {{ block.shopify_attributes }}>
            <a
              href="{{ block.settings.link | default: routes.collections_url }}"
              class="cat-tile"
              aria-label="{{ tile_title | escape }}{% if block.settings.subtitle != blank %} - {{ block.settings.subtitle | escape }}{% endif %}"
            >
              <div class="cat-tile__media">
                {%- if block.settings.image != blank -%}
                  {%- assign cat_img_alt = block.settings.image_alt | default: tile_title -%}
                  {{
                    block.settings.image
                    | image_url: width: 900
                    | image_tag:
                      loading: 'lazy',
                      decoding: 'async',
                      alt: cat_img_alt,
                      width: block.settings.image.width,
                      height: block.settings.image.height,
                      widths: '400, 600, 800, 900',
                      sizes: '(max-width: 599px) calc(50vw - 20px), (max-width: 1023px) calc(50vw - 32px), calc((min(100vw, 1280px) - 96px - (var(--desktop-cols) - 1) * var(--grid-gap)) / var(--desktop-cols))',
                      class: 'cat-tile__img'
                  }}
                {%- else -%}
                  {%- if title_downcase contains 'women' -%}
                    <img class="cat-tile__img" src="{{ 'tile-womens-style.png' | asset_url }}" alt="{{ fallback_alt }}" width="800" height="1000" loading="lazy" decoding="async">
                  {%- elsif title_downcase contains 'men' -%}
                    <img class="cat-tile__img" src="{{ 'tile-mens-lace-up.webp' | asset_url }}" alt="{{ fallback_alt }}" width="800" height="1000" loading="lazy" decoding="async">
                  {%- elsif title_downcase contains 'on' or title_downcase contains 'athletic' or title_downcase contains 'performance' -%}
                    <img class="cat-tile__img" src="{{ 'tile-athletic-lacing.webp' | asset_url }}" alt="{{ fallback_alt }}" width="800" height="1000" loading="lazy" decoding="async">
                  {%- elsif title_downcase contains 'dance' -%}
                    <img class="cat-tile__img" src="{{ 'tile-dance-lifestyle.webp' | asset_url }}" alt="{{ fallback_alt }}" width="800" height="1000" loading="lazy" decoding="async">
                  {%- elsif title_downcase contains 'sale' -%}
                    <img class="cat-tile__img" src="{{ 'tile-sale.webp' | asset_url }}" alt="{{ fallback_alt }}" width="800" height="1000" loading="lazy" decoding="async">
                  {%- else -%}
                    <img class="cat-tile__img" src="{{ 'tile-womens-style.png' | asset_url }}" alt="{{ fallback_alt }}" width="800" height="1000" loading="lazy" decoding="async">
                  {%- endif -%}
                {%- endif -%}
              </div>

              <div class="cat-tile__content">
                {%- if block.settings.subtitle != blank -%}
                  <p class="cat-tile__subtitle">{{ block.settings.subtitle | escape }}</p>
                {%- endif -%}
                <{{ tile_heading_tag }} class="cat-tile__title">{{ tile_title | escape }}</{{ tile_heading_tag }}>
              </div>
            </a>
          </li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      <ul class="cat-tiles__grid" role="list" style="--desktop-cols: 4; --tile-aspect: 4 / 5;">
        <li class="cat-tiles__item">
          <a href="{{ routes.collections_url }}" class="cat-tile" aria-label="Women's - Shop now">
            <div class="cat-tile__media">
              <img class="cat-tile__img" src="{{ 'tile-womens-style.png' | asset_url }}" alt="Women's shoes category image" width="800" height="1000" loading="lazy" decoding="async">
            </div>
            <div class="cat-tile__content">
              <p class="cat-tile__subtitle">Shop now</p>
              <h3 class="cat-tile__title">Women's</h3>
            </div>
          </a>
        </li>
        <li class="cat-tiles__item">
          <a href="{{ routes.collections_url }}" class="cat-tile" aria-label="Men's - Shop now">
            <div class="cat-tile__media">
              <img class="cat-tile__img" src="{{ 'tile-mens-lace-up.webp' | asset_url }}" alt="Men's shoes category image" width="800" height="1000" loading="lazy" decoding="async">
            </div>
            <div class="cat-tile__content">
              <p class="cat-tile__subtitle">Shop now</p>
              <h3 class="cat-tile__title">Men's</h3>
            </div>
          </a>
        </li>
        <li class="cat-tiles__item">
          <a href="{{ routes.collections_url }}" class="cat-tile" aria-label="On Running - Performance favorites">
            <div class="cat-tile__media">
              <img class="cat-tile__img" src="{{ 'tile-athletic-lacing.webp' | asset_url }}" alt="On Running category image" width="800" height="1000" loading="lazy" decoding="async">
            </div>
            <div class="cat-tile__content">
              <p class="cat-tile__subtitle">Performance favorites</p>
              <h3 class="cat-tile__title">On Running</h3>
            </div>
          </a>
        </li>
        <li class="cat-tiles__item">
          <a href="{{ routes.collections_url }}" class="cat-tile" aria-label="Dance - Move well">
            <div class="cat-tile__media">
              <img class="cat-tile__img" src="{{ 'tile-dance-lifestyle.webp' | asset_url }}" alt="Dance category image" width="800" height="1000" loading="lazy" decoding="async">
            </div>
            <div class="cat-tile__content">
              <p class="cat-tile__subtitle">Move well</p>
              <h3 class="cat-tile__title">Dance</h3>
            </div>
          </a>
        </li>
      </ul>
    {%- endif -%}
  </div>
</section>

<style>
  .cat-tiles {
    background-color: var(--color-bg);
  }

  .cat-tiles__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
    margin-bottom: 48px;
  }

  .cat-tiles__heading {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: var(--font-size-h2);
    letter-spacing: var(--heading-letter-spacing);
    color: var(--color-heading);
  }

  .cat-tiles__subheading {
    margin: 0;
    max-width: 520px;
    font-size: clamp(15px, 1.4vw, 17px);
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  .cat-tiles__grid {
    display: grid;
    grid-template-columns: repeat(var(--desktop-cols, 4), 1fr);
    gap: var(--grid-gap);
  }

  .cat-tiles__item {
    list-style: none;
  }

  .cat-tile {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: var(--radius-card);
    text-decoration: none;
    background-color: var(--color-card);
  }

  .cat-tile::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.68) 0%, rgba(0, 0, 0, 0.20) 40%, transparent 65%);
    transition: opacity 0.35s ease;
  }

  .cat-tile::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    background-color: var(--color-accent);
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .cat-tile:hover::after,
  .cat-tile:focus-visible::after {
    opacity: 0.20;
  }

  .cat-tile:hover::before,
  .cat-tile:focus-visible::before {
    opacity: 0.9;
  }

  .cat-tile__img {
    display: block;
    width: 100%;
    aspect-ratio: var(--tile-aspect, 4 / 5);
    object-fit: cover;
    object-position: center top;
    transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .cat-tile:hover .cat-tile__img,
  .cat-tile:focus-visible .cat-tile__img {
    transform: scale(1.06);
  }

  .cat-tile__content {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    padding: 16px 20px 24px;
    text-align: center;
  }

  .cat-tile__subtitle {
    margin: 0;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    line-height: 1;
    color: rgba(255, 255, 255, 0.70);
    transition: color 0.25s ease;
  }

  .cat-tile:hover .cat-tile__subtitle,
  .cat-tile:focus-visible .cat-tile__subtitle {
    color: rgba(255, 255, 255, 0.95);
  }

  .cat-tile__title {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: clamp(17px, 1.8vw, 22px);
    letter-spacing: 0.08em;
    line-height: 1.1;
    text-transform: uppercase;
    color: #FFFFFF;
    transition: letter-spacing 0.3s ease;
  }

  .cat-tile:hover .cat-tile__title,
  .cat-tile:focus-visible .cat-tile__title {
    letter-spacing: 0.13em;
  }

  .cat-tile:focus-visible {
    outline: 3px solid #005FCC;
    outline-offset: 3px;
  }

  @media (max-width: 1023px) and (min-width: 600px) {
    .cat-tiles__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 599px) {
    .cat-tiles__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--grid-gap-mobile, 12px);
    }

    .cat-tiles__header {
      margin-bottom: 28px;
    }

    .cat-tile__content {
      padding: 10px 12px 16px;
      gap: 3px;
    }
  }
</style>

{% schema %}
{
  "name": "Featured categories",
  "tag": "section",
  "class": "cat-tiles-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "placeholder": "Shop by Category",
      "info": "Optional. Leave blank to show only the tiles with no heading above them."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "placeholder": "Comfort, style, and dance shoes for the whole family.",
      "info": "Optional. Appears below the heading in muted text."
    },
    {
      "type": "header",
      "content": "Grid layout"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (desktop)",
      "options": [
        { "value": "2", "label": "2 columns - large tiles" },
        { "value": "3", "label": "3 columns - medium tiles" },
        { "value": "4", "label": "4 columns - standard (recommended)" }
      ],
      "default": "4",
      "info": "Mobile always shows 2 columns."
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Tile shape",
      "options": [
        { "value": "square", "label": "Square - 1:1" },
        { "value": "portrait", "label": "Portrait - 4:5 (recommended)" },
        { "value": "tall", "label": "Tall portrait - 3:4" }
      ],
      "default": "portrait",
      "info": "Portrait (4:5) shows more of the shoe and model."
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Category tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category image",
          "info": "Lifestyle photography works best."
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text",
          "info": "Describe the image for screen readers and SEO."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category name",
          "default": "Women's Shoes"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Callout text",
          "default": "Shop Now",
          "placeholder": "Shop Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured categories",
      "settings": {
        "columns": "4",
        "aspect_ratio": "portrait"
      },
      "blocks": [
        {
          "type": "tile",
          "settings": {
            "title": "Women's Shoes",
            "subtitle": "Shop Now"
          }
        },
        {
          "type": "tile",
          "settings": {
            "title": "Men's Shoes",
            "subtitle": "Shop Now"
          }
        },
        {
          "type": "tile",
          "settings": {
            "title": "On Running",
            "subtitle": "Performance Favorites"
          }
        },
        {
          "type": "tile",
          "settings": {
            "title": "Dance",
            "subtitle": "Move Well"
          }
        }
      ]
    }
  ]
}
{% endschema %}
