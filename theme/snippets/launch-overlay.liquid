{%- if settings.launch_overlay_enabled and settings.launch_overlay_heading != blank and settings.launch_overlay_primary_label != blank -%}
  <div
    class="launch-overlay"
    data-launch-overlay
    data-home-only="{{ settings.launch_overlay_home_only }}"
    data-frequency-days="{{ settings.launch_overlay_frequency_days }}"
    aria-hidden="true"
    hidden
  >
    <div class="launch-overlay__backdrop" data-launch-overlay-close></div>
    <div class="launch-overlay__dialog" role="dialog" aria-modal="true" aria-labelledby="LaunchOverlayHeading">
      <button class="launch-overlay__close" type="button" aria-label="Close launch message" data-launch-overlay-close>
        x
      </button>

      <div class="launch-overlay__media">
        {%- if settings.launch_overlay_image != blank -%}
          {{ settings.launch_overlay_image | image_url: width: 1800 | image_tag: loading: 'eager', class: 'launch-overlay__image', alt: settings.launch_overlay_image_alt }}
        {%- else -%}
          <img src="{{ 'tile-dance-lifestyle.webp' | asset_url }}" alt="{{ settings.launch_overlay_image_alt | escape }}" width="1400" height="900" loading="eager" class="launch-overlay__image">
        {%- endif -%}
      </div>

      <div class="launch-overlay__content">
        {%- if settings.launch_overlay_eyebrow != blank -%}
          <p class="launch-overlay__eyebrow">{{ settings.launch_overlay_eyebrow | escape }}</p>
        {%- endif -%}
        <h2 id="LaunchOverlayHeading" class="launch-overlay__heading">{{ settings.launch_overlay_heading | escape }}</h2>
        {%- if settings.launch_overlay_text != blank -%}
          <p class="launch-overlay__text">{{ settings.launch_overlay_text | escape }}</p>
        {%- endif -%}
        <div class="launch-overlay__actions">
          <a href="{{ settings.launch_overlay_primary_url | default: routes.root_url }}" class="btn" data-launch-overlay-action>
            {{ settings.launch_overlay_primary_label | escape }}
          </a>
          <a href="{{ settings.launch_overlay_secondary_url | default: routes.root_url }}" class="launch-overlay__secondary" data-launch-overlay-action>
            {{ settings.launch_overlay_secondary_label | default: 'Enter Store' | escape }}
          </a>
        </div>
      </div>
    </div>
  </div>

  <style>
    .launch-overlay[hidden] { display: none; }
    .launch-overlay { position: fixed; inset: 0; z-index: 9999; }
    .launch-overlay__backdrop { position: absolute; inset: 0; background: rgba(10, 14, 18, 0.68); backdrop-filter: blur(4px); }
    .launch-overlay__dialog {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
      width: min(1100px, calc(100% - 32px));
      min-height: min(720px, calc(100vh - 32px));
      margin: 16px auto;
      background: #111922;
      border-radius: 26px;
      overflow: hidden;
      box-shadow: 0 28px 90px rgba(0, 0, 0, 0.35);
    }
    .launch-overlay__close {
      position: absolute;
      top: 18px;
      right: 18px;
      z-index: 2;
      width: 42px;
      height: 42px;
      border: 1px solid rgba(247, 241, 230, 0.28);
      border-radius: 999px;
      background: rgba(17, 25, 34, 0.55);
      color: #f7f1e6;
      font: inherit;
      cursor: pointer;
    }
    .launch-overlay__media, .launch-overlay__image { width: 100%; height: 100%; }
    .launch-overlay__image { display: block; object-fit: cover; object-position: center; }
    .launch-overlay__content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: clamp(28px, 5vw, 52px);
      background: linear-gradient(180deg, rgba(17, 25, 34, 0.96), rgba(50, 34, 18, 0.92));
      color: #f7f1e6;
    }
    .launch-overlay__eyebrow { margin: 0 0 14px; font-size: 11px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(247, 241, 230, 0.7); }
    .launch-overlay__heading { margin: 0; font-size: clamp(34px, 4vw, 56px); line-height: 0.98; color: #f7f1e6; }
    .launch-overlay__text { margin: 18px 0 0; font-size: 17px; line-height: 1.75; color: rgba(247, 241, 230, 0.84); }
    .launch-overlay__actions { display: grid; gap: 16px; margin-top: 28px; }
    .launch-overlay__secondary { color: #f7f1e6; font-size: 13px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: underline; text-underline-offset: 4px; }
    @media (max-width: 767px) {
      .launch-overlay__dialog { grid-template-columns: 1fr; min-height: calc(100vh - 24px); width: calc(100% - 24px); margin: 12px auto; }
      .launch-overlay__media { min-height: 36vh; }
    }
  </style>
{%- endif -%}
