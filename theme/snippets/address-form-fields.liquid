{% comment %}
  snippets/address-form-fields.liquid
  ─────────────────────────────────────────────────────────────────────────────
  Reusable address form field set. Used by both the "add new address" panel
  and each inline "edit address" panel in templates/customers/addresses.liquid.

  Parameters:
    address {object} Required. Either customer.new_address or a saved address.
    form_id {string} Required. Unique suffix for <label for> / <input id> pairs
                     (use "new" for new address, address.id for edit forms).
{% endcomment %}

<div class="address-form__grid">

  <div class="address-form__field">
    <label for="AddressFirstName-{{ form_id }}">First name</label>
    <input
      type="text"
      id="AddressFirstName-{{ form_id }}"
      name="address[first_name]"
      value="{{ address.first_name | escape }}"
      autocomplete="given-name"
    >
  </div>

  <div class="address-form__field">
    <label for="AddressLastName-{{ form_id }}">Last name</label>
    <input
      type="text"
      id="AddressLastName-{{ form_id }}"
      name="address[last_name]"
      value="{{ address.last_name | escape }}"
      autocomplete="family-name"
    >
  </div>

  <div class="address-form__field address-form__field--full">
    <label for="AddressCompany-{{ form_id }}">Company <span style="font-weight:400;color:var(--color-text-secondary)">(optional)</span></label>
    <input
      type="text"
      id="AddressCompany-{{ form_id }}"
      name="address[company]"
      value="{{ address.company | escape }}"
      autocomplete="organization"
    >
  </div>

  <div class="address-form__field address-form__field--full">
    <label for="AddressAddress1-{{ form_id }}">Address</label>
    <input
      type="text"
      id="AddressAddress1-{{ form_id }}"
      name="address[address1]"
      value="{{ address.address1 | escape }}"
      autocomplete="address-line1"
      required
    >
  </div>

  <div class="address-form__field address-form__field--full">
    <label for="AddressAddress2-{{ form_id }}">Apartment, suite, etc. <span style="font-weight:400;color:var(--color-text-secondary)">(optional)</span></label>
    <input
      type="text"
      id="AddressAddress2-{{ form_id }}"
      name="address[address2]"
      value="{{ address.address2 | escape }}"
      autocomplete="address-line2"
    >
  </div>

  <div class="address-form__field">
    <label for="AddressCity-{{ form_id }}">City</label>
    <input
      type="text"
      id="AddressCity-{{ form_id }}"
      name="address[city]"
      value="{{ address.city | escape }}"
      autocomplete="address-level2"
      required
    >
  </div>

  <div class="address-form__field">
    <label for="AddressZip-{{ form_id }}">ZIP / Postal code</label>
    <input
      type="text"
      id="AddressZip-{{ form_id }}"
      name="address[zip]"
      value="{{ address.zip | escape }}"
      autocomplete="postal-code"
    >
  </div>

  <div class="address-form__field">
    <label for="AddressProvince-{{ form_id }}">State / Province</label>
    <input
      type="text"
      id="AddressProvince-{{ form_id }}"
      name="address[province]"
      value="{{ address.province | escape }}"
      autocomplete="address-level1"
    >
  </div>

  <div class="address-form__field">
    <label for="AddressCountry-{{ form_id }}">Country</label>
    <select
      id="AddressCountry-{{ form_id }}"
      name="address[country]"
      autocomplete="country"
    >
      {{ all_country_option_tags }}
    </select>
  </div>

  <div class="address-form__field address-form__field--full">
    <label for="AddressPhone-{{ form_id }}">Phone <span style="font-weight:400;color:var(--color-text-secondary)">(optional)</span></label>
    <input
      type="tel"
      id="AddressPhone-{{ form_id }}"
      name="address[phone]"
      value="{{ address.phone | escape }}"
      autocomplete="tel"
    >
  </div>

  <div class="address-form__field address-form__field--full">
    <label style="display:flex;align-items:center;gap:10px;font-weight:400;cursor:pointer;">
      <input
        type="checkbox"
        name="address[default]"
        value="true"
        {% if address.id == customer.default_address.id %}checked{% endif %}
        style="width:auto;accent-color:var(--color-accent);"
      >
      Set as default address
    </label>
  </div>

</div><!-- /.address-form__grid -->
