{% comment %}
  snippets/cart-drawer.liquid
  ─────────────────────────────────────────────────────────────────────────────
  Cart slide-in drawer. Rendered once in layout/theme.liquid.
  JS in assets/theme.js controls the CartDrawer custom element:
    - Open/close via aria-hidden + inert on the panel
    - Items populated dynamically from the Shopify Cart AJAX API
    - Subtotal updated after every quantity/remove operation

  Accessibility:
    - aria-hidden="true" on <cart-drawer> when closed; false when open
    - inert on the panel prevents keyboard interaction when drawer is closed
    - Focus trapped inside panel when open (managed by JS)
    - aria-live="polite" on items region announces cart updates to screen readers
{% endcomment %}

<cart-drawer
  aria-hidden="true"
  aria-label="Shopping cart"
  id="CartDrawer"
>
  <!-- Scrim overlay — click to close -->
  <div class="cart-drawer__overlay" aria-hidden="true"></div>

  <!-- Sliding panel -->
  <div class="cart-drawer__panel" inert>

    <!-- ── Header ─────────────────────────────────────────────────────── -->
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">Your Cart</h2>
      <button
        class="cart-drawer__close"
        data-cart-drawer-close
        aria-label="Close cart"
        type="button"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round"
          aria-hidden="true" focusable="false">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <!-- ── Body (items) ───────────────────────────────────────────────── -->
    <div class="cart-drawer__body">

      <!-- Items populated by JS after API call -->
      <div
        class="cart-drawer__items"
        role="region"
        aria-label="Cart items"
        aria-live="polite"
        aria-atomic="false"
      ></div>

      <!-- Empty state — toggled by JS when cart has 0 items -->
      <p class="cart-drawer__empty" hidden>
        Your cart is empty — start with a comfortable step.
        <a href="{{ routes.collections_url }}" class="cart-drawer__shop-link">Shop shoes</a>
      </p>

    </div>

    <!-- ── Footer (subtotal + checkout) ──────────────────────────────── -->
    <div class="cart-drawer__footer" hidden>
      <div class="cart-drawer__subtotal-row">
        <span class="cart-drawer__subtotal-label">Subtotal</span>
        <span class="cart-drawer__subtotal-value" data-cart-subtotal></span>
      </div>
      <p class="cart-drawer__note">Shipping &amp; taxes calculated at checkout.</p>
      <a
        href="{{ routes.checkout_url }}"
        class="btn btn--full cart-drawer__checkout"
      >
        Checkout
      </a>
      <a href="{{ routes.cart_url }}" class="cart-drawer__view-cart">
        View full cart
      </a>
    </div>

  </div><!-- /.cart-drawer__panel -->
</cart-drawer>

<style>
  /* ── Cart Drawer ─────────────────────────────────────────────────────────
     The drawer uses aria-hidden to communicate open/close state.
     Transitions are on transform (panel) and opacity (overlay) for smooth
     60fps animation — these properties don't trigger layout.
  ─────────────────────────────────────────────────────────────────────── */

  /* Custom element: full-screen fixed stacking context */
  cart-drawer {
    --drawer-width: 400px;
    position: fixed;
    inset: 0;
    z-index: 900;
    /* Pointer events disabled when hidden — clicks pass through to page */
    pointer-events: none;
  }

  /* Open state */
  cart-drawer:not([aria-hidden="true"]) {
    pointer-events: all;
  }

  /* ── Overlay (scrim) ─────────────────────────────────────────────────── */
  .cart-drawer__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.45);
    /* Frosted glass — remove if performance is a concern on low-end devices */
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 0.3s ease;
    cursor: pointer;
  }

  cart-drawer:not([aria-hidden="true"]) .cart-drawer__overlay {
    opacity: 1;
  }

  /* ── Panel ──────────────────────────────────────────────────────────── */
  .cart-drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: var(--drawer-width);
    max-width: 100vw;
    background-color: var(--color-bg, #FAF9F6);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    /* Subtle shadow to separate from page content beneath the scrim */
    box-shadow: -4px 0 32px rgba(0, 0, 0, 0.12);
    overflow: hidden;
  }

  cart-drawer:not([aria-hidden="true"]) .cart-drawer__panel {
    transform: translateX(0);
  }

  /* ── Header (sticky) ────────────────────────────────────────────────── */
  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    border-bottom: 1px solid var(--color-border, #EBEBEB);
    flex-shrink: 0;
    background-color: var(--color-bg, #FAF9F6);
    /* Sticky within the flex column */
    position: sticky;
    top: 0;
    z-index: 1;
  }

  .cart-drawer__title {
    margin: 0;
    font-family: var(--font-heading, sans-serif);
    font-weight: 700;
    font-size: 18px;
    letter-spacing: 0.04em;
    color: var(--color-heading, #000000);
    line-height: 1;
  }

  .cart-drawer__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--color-border, #EBEBEB);
    border-radius: 50%;
    background: none;
    cursor: pointer;
    color: var(--color-text, #3D3D3D);
    transition: background-color 0.18s ease, border-color 0.18s ease;
    flex-shrink: 0;
  }

  .cart-drawer__close:hover {
    background-color: var(--color-accent, #F5E1E1);
    border-color: var(--color-accent, #F5E1E1);
  }

  .cart-drawer__close:focus-visible {
    outline: 3px solid #005FCC;
    outline-offset: 2px;
  }

  /* ── Body (scrollable) ──────────────────────────────────────────────── */
  .cart-drawer__body {
    flex: 1;
    overflow-y: auto;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
    padding: 16px 24px;
    display: flex;
    flex-direction: column;
  }

  /* ── Individual item (rendered by JS) ──────────────────────────────── */
  .cart-drawer__item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 14px;
    padding: 16px 0;
    border-bottom: 1px solid var(--color-border, #EBEBEB);
  }

  .cart-drawer__item:first-child {
    padding-top: 0;
  }

  .cart-drawer__item-img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: var(--radius-card, 12px);
    background-color: var(--color-card, #FFFFFF);
    display: block;
    flex-shrink: 0;
  }

  .cart-drawer__item-details {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .cart-drawer__item-vendor {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-secondary, #A8A8A8);
    margin: 0;
  }

  .cart-drawer__item-title {
    font-family: var(--font-heading, sans-serif);
    font-size: 13px;
    font-weight: 700;
    color: var(--color-heading, #000000);
    margin: 0;
    line-height: 1.3;
    /* Truncate long titles to 2 lines */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cart-drawer__item-title a {
    color: inherit;
    text-decoration: none;
  }

  .cart-drawer__item-variant {
    font-size: 12px;
    color: var(--color-text-secondary, #A8A8A8);
    margin: 0;
  }

  /* Qty + price + remove row */
  .cart-drawer__item-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 6px;
    gap: 8px;
  }

  /* Quantity stepper */
  .cart-drawer__qty {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1px solid var(--color-border, #EBEBEB);
    border-radius: var(--radius-btn, 8px);
    overflow: hidden;
    height: 32px;
  }

  .cart-drawer__qty-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 32px;
    border: none;
    background: none;
    cursor: pointer;
    color: var(--color-text, #3D3D3D);
    font-size: 16px;
    line-height: 1;
    transition: background-color 0.15s ease;
  }

  .cart-drawer__qty-btn:hover {
    background-color: var(--color-accent, #F5E1E1);
  }

  .cart-drawer__qty-btn:focus-visible {
    outline: 3px solid #005FCC;
    outline-offset: -2px;
  }

  .cart-drawer__qty-input {
    width: 36px;
    height: 32px;
    border: none;
    border-left: 1px solid var(--color-border, #EBEBEB);
    border-right: 1px solid var(--color-border, #EBEBEB);
    text-align: center;
    font-family: var(--font-body, sans-serif);
    font-size: 13px;
    font-weight: 600;
    background: none;
    color: var(--color-heading, #000000);
    -moz-appearance: textfield;
  }

  .cart-drawer__qty-input::-webkit-outer-spin-button,
  .cart-drawer__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .cart-drawer__item-price {
    font-family: var(--font-body, sans-serif);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-heading, #000000);
    white-space: nowrap;
  }

  .cart-drawer__remove {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-secondary, #A8A8A8);
    border-radius: 4px;
    transition: color 0.18s ease, background-color 0.18s ease;
    flex-shrink: 0;
  }

  .cart-drawer__remove:hover {
    color: #A83232;
    background-color: rgba(168, 50, 50, 0.08);
  }

  .cart-drawer__remove:focus-visible {
    outline: 3px solid #005FCC;
    outline-offset: 2px;
  }

  /* ── Empty state ────────────────────────────────────────────────────── */
  .cart-drawer__empty {
    text-align: center;
    padding: 40px 0;
    color: var(--color-text-secondary, #A8A8A8);
    font-size: 15px;
    line-height: 1.7;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin: auto 0;
  }

  .cart-drawer__shop-link {
    display: inline-block;
    padding: 10px 24px;
    background-color: var(--color-accent, #F5E1E1);
    color: var(--color-heading, #000000);
    border-radius: var(--radius-btn, 8px);
    font-family: var(--font-body, sans-serif);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background-color 0.18s ease;
  }

  .cart-drawer__shop-link:hover {
    background-color: var(--color-accent-hover, #E8C8C8);
  }

  /* ── Footer (sticky bottom) ─────────────────────────────────────────── */
  .cart-drawer__footer {
    flex-shrink: 0;
    padding: 20px 24px;
    border-top: 1px solid var(--color-border, #EBEBEB);
    background-color: var(--color-bg, #FAF9F6);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cart-drawer__subtotal-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
  }

  .cart-drawer__subtotal-label {
    font-family: var(--font-heading, sans-serif);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-heading, #000000);
  }

  .cart-drawer__subtotal-value {
    font-family: var(--font-body, sans-serif);
    font-size: 18px;
    font-weight: 700;
    color: var(--color-heading, #000000);
  }

  .cart-drawer__note {
    margin: 0;
    font-size: 12px;
    color: var(--color-text-secondary, #A8A8A8);
    text-align: center;
    line-height: 1.5;
  }

  .cart-drawer__checkout {
    /* btn btn--full classes cover most of this; just ensure margin */
    margin-top: 4px;
  }

  .cart-drawer__view-cart {
    display: block;
    text-align: center;
    font-size: 13px;
    color: var(--color-text-secondary, #A8A8A8);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.18s ease;
  }

  .cart-drawer__view-cart:hover {
    color: var(--color-text, #3D3D3D);
  }

  .cart-drawer__view-cart:focus-visible {
    outline: 3px solid #005FCC;
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* Narrow panel on mobile — full width below 400px */
  @media (max-width: 420px) {
    cart-drawer {
      --drawer-width: 100vw;
    }
  }

  /* Reduced motion — skip slide-in animation */
  @media (prefers-reduced-motion: reduce) {
    .cart-drawer__panel {
      transition: visibility 0.01s;
      transform: translateX(0);
      visibility: hidden;
    }
    cart-drawer:not([aria-hidden="true"]) .cart-drawer__panel {
      visibility: visible;
    }
    .cart-drawer__overlay {
      transition: opacity 0.01s;
    }
  }
</style>

