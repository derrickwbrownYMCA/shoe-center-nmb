{% comment %}
  snippets/price.liquid
  Renders product pricing with sale and unit-price support.
{% endcomment %}

{%- liquid
  if variant
    assign target_variant = variant
  else
    assign target_variant = product.selected_or_first_available_variant
  endif

  if show_compare == false
    assign display_compare = false
  else
    assign display_compare = true
  endif

  if target_variant
    assign current_price = target_variant.price
    assign compare_at_price = target_variant.compare_at_price
    assign price_varies = false
  else
    assign current_price = product.price
    assign compare_at_price = product.compare_at_price
    assign price_varies = product.price_varies
  endif

  assign is_on_sale = false
  if compare_at_price != blank and compare_at_price > current_price
    assign is_on_sale = true
  endif

  assign show_unit_price = false
  if target_variant and target_variant.unit_price_measurement
    assign show_unit_price = true
  endif
-%}

<div class="price{% if is_on_sale %} price--on-sale{% endif %}">
  <div class="price__row">
    {%- if price_varies and target_variant == nil -%}
      <span class="price__current{% if is_on_sale %} price__current--sale{% endif %}" aria-label="From {{ product.price_min | money }}">
        <span class="visually-hidden">From </span>{{- product.price_min | money -}}
      </span>
    {%- elsif is_on_sale -%}
      <span class="visually-hidden">Sale price: </span>
      <span class="price__current price__current--sale">{{- current_price | money -}}</span>
      {%- if display_compare -%}
        <s class="price__compare">
          <span class="visually-hidden">Regular price: </span>{{- compare_at_price | money -}}
        </s>
      {%- endif -%}
    {%- else -%}
      <span class="price__current">{{- current_price | money -}}</span>
    {%- endif -%}
  </div>

  {%- if show_unit_price -%}
    {%- assign unit = target_variant.unit_price_measurement -%}
    <div class="price__unit" aria-label="Unit price">
      {{- target_variant.unit_price | money -}}
      <span aria-hidden="true">/</span>
      {%- if unit.reference_value != 1 -%}{{- unit.reference_value -}}{%- endif -%}
      {{- unit.reference_unit -}}
    </div>
  {%- endif -%}
</div>
