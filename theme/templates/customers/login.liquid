{% comment %} templates/customers/login.liquid {% endcomment %}
<main id="MainContent" class="section-padding" role="main" tabindex="-1">
  <div class="container" style="max-width:480px;">
    <h1>Sign In</h1>
    {% form 'customer_login' %}
      {{ form.errors | default_errors }}
      <div style="display:flex;flex-direction:column;gap:14px;margin-top:24px;">
        <div>
          <label for="CustomerEmail">Email</label>
          <input
            type="email"
            name="customer[email]"
            id="CustomerEmail"
            autocomplete="email"
            required
            style="width:100%;padding:12px;border:1px solid var(--color-border,#EBEBEB);border-radius:8px;font-size:16px;margin-top:6px;"
          >
        </div>
        <div>
          <label for="CustomerPassword">Password</label>
          <input
            type="password"
            name="customer[password]"
            id="CustomerPassword"
            autocomplete="current-password"
            required
            style="width:100%;padding:12px;border:1px solid var(--color-border,#EBEBEB);border-radius:8px;font-size:16px;margin-top:6px;"
          >
        </div>
        <button type="submit" class="btn btn--full" style="margin-top:8px;">Sign In</button>
        <p style="text-align:center;font-size:14px;color:var(--color-text-secondary,#A8A8A8);">
          <a href="{{ routes.account_recover_url }}">Forgot your password?</a>
          &ensp;·&ensp;
          <a href="{{ routes.account_register_url }}">Create account</a>
        </p>
      </div>
    {% endform %}
  </div>
</main>
